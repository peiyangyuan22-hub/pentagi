# PentAGI Environment Variables
# https://github.com/vxcontrol/pentagi
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Required: at least ONE LLM provider and DATABASE_URL (default works for Docker)

# ─── LLM Provider (set at least ONE) ──────────────────────
# OpenAI
OPEN_AI_KEY=
# OPEN_AI_SERVER_URL=https://api.openai.com/v1

# Anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_SERVER_URL=https://api.anthropic.com/v1

# Ollama (local)
# OLLAMA_SERVER_URL=http://host.docker.internal:11434
# OLLAMA_SERVER_MODEL=llama3

# DeepSeek
# DEEPSEEK_API_KEY=

# Google Gemini
# GEMINI_API_KEY=

# GLM (Zhipu AI)
# GLM_API_KEY=

# Kimi (Moonshot AI)
# KIMI_API_KEY=

# Qwen (Tongyi Qianwen)
# QWEN_API_KEY=

# AWS Bedrock
# BEDROCK_REGION=us-east-1
# BEDROCK_ACCESS_KEY_ID=
# BEDROCK_SECRET_ACCESS_KEY=

# Custom LLM (OpenAI-compatible)
# LLM_SERVER_URL=
# LLM_SERVER_KEY=
# LLM_SERVER_MODEL=

# ─── Database ──────────────────────────────────────────────
# Default (Docker): postgres://pentagiuser:pentagipass@pgvector:5432/pentagidb?sslmode=disable
DATABASE_URL=postgres://pentagiuser:pentagipass@pgvector:5432/pentagidb?sslmode=disable

# ─── Server ────────────────────────────────────────────────
# SERVER_PORT=8080
# SERVER_HOST=0.0.0.0
# DEBUG=false
# DATA_DIR=./data

# ─── Security ──────────────────────────────────────────────
# COOKIE_SIGNING_SALT=<generate a random string>

# ─── Docker ────────────────────────────────────────────────
# DOCKER_SOCKET=/var/run/docker.sock
# DOCKER_DEFAULT_IMAGE=debian:latest
# DOCKER_DEFAULT_IMAGE_FOR_PENTEST=vxcontrol/kali-linux

# ─── Optional: Search ──────────────────────────────────────
# GOOGLE_API_KEY=
# GOOGLE_CX_KEY=
# TAVILY_API_KEY=
# PERPLEXITY_API_KEY=

# ─── Optional: OAuth ───────────────────────────────────────
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=
# OAUTH_GITHUB_CLIENT_ID=
# OAUTH_GITHUB_CLIENT_SECRET=

# ─── Optional: Observability ──────────────────────────────
# OTEL_HOST=
# LANGFUSE_BASE_URL=
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=

# ─── Optional: Knowledge Graph ────────────────────────────
# GRAPHITI_ENABLED=false
# GRAPHITI_URL=

# ─── Optional: Proxy ──────────────────────────────────────
# PROXY_URL=

# ─── Advanced: Agent Settings ─────────────────────────────
# MAX_GENERAL_AGENT_TOOL_CALLS=100
# MAX_LIMITED_AGENT_TOOL_CALLS=20
# EXECUTION_MONITOR_ENABLED=false

# ─── Advanced: Embedding ──────────────────────────────────
# EMBEDDING_PROVIDER=openai
# EMBEDDING_URL=
# EMBEDDING_KEY=
# EMBEDDING_MODEL=

# ─── Advanced: Ollama ─────────────────────────────────────
# OLLAMA_SERVER_PULL_MODELS_ENABLED=false
# OLLAMA_SERVER_LOAD_MODELS_ENABLED=false
# OLLAMA_SERVER_PULL_MODELS_TIMEOUT=600

# ─── Advanced: Summarizer ─────────────────────────────────
# SUMMARIZER_PRESERVE_LAST=true
# SUMMARIZER_USE_QA=true
# SUMMARIZER_LAST_SEC_BYTES=51200
# SUMMARIZER_MAX_BP_BYTES=16384
# SUMMARIZER_MAX_QA_SECTIONS=10
