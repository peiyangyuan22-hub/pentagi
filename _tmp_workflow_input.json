{
  "workflow_name": "PentAGI CI/CD Pipeline",
  "trigger": "on-push-to-develop",
  "steps": [
    {"name": "Run Go Tests", "type": "task", "on_failure": "stop"},
    {"name": "Run Frontend Tests", "type": "task", "on_failure": "stop"},
    {"name": "Build Docker Images", "type": "task", "on_failure": "stop"},
    {"name": "Security Scan", "type": "task", "on_failure": "stop"},
    {"name": "Code Review", "type": "llm", "on_failure": "stop"},
    {"name": "Create PR to main", "type": "task", "on_failure": "notify"},
    {"name": "Deploy to Staging", "type": "task", "on_failure": "notify"},
    {"name": "Notify Team", "type": "task", "on_failure": "skip"}
  ]
}
